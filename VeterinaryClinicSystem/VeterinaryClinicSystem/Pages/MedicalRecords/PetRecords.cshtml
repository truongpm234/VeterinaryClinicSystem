@page "{petId:int}"
@model VeterinaryClinicSystem.Pages.MedicalRecords.PetRecordsModel

@{
    ViewData["Title"] = "Hồ sơ bệnh án của thú cưng";
}

<h2>Hồ sơ bệnh án của @Model.PetName</h2>

<table class="table">
    <thead>
        <tr>
            <th>Mã hồ sơ</th>
            <th>Chẩn đoán</th>
            <th>Kế hoạch điều trị</th>
            <th>Ngày tái khám</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var record in Model.Records)
        {
            <tr>
                <td>@record.RecordId</td>
                <td>@record.Diagnosis</td>
                <td>@record.TreatmentPlan</td>
                <td>@record.FollowUpDate?.ToString("yyyy-MM-dd")</td>
            </tr>
        }
    </tbody>
</table>
